---
import { STRINGS, localePath, APP_STORE_URL } from '../i18n/locales.js';
const { locale } = Astro.props;
const t = STRINGS[locale];
const c = t.calc;
---

<section class="section">
  <div class="wrap">
    <span class="eyebrow">RxDown</span>
    <h1>{c.h1}</h1>
    <p class="lede" style="max-width:52rem">{c.answerFirst}</p>

    <div class="calc-panel">
      <div class="calc-grid">
        <div class="field">
          <label for="calc-dose">{c.labelStart}</label>
          <input id="calc-dose" type="number" inputmode="decimal" min="0.1" step="any" value="20" />
        </div>
        <div class="field">
          <label for="calc-unit">{c.labelUnit}</label>
          <select id="calc-unit">
            <option value="mg" selected>mg</option>
            <option value="ml">mL</option>
            <option value="µg">µg</option>
          </select>
        </div>
        <div class="field">
          <label for="calc-pct">{c.labelPercent}</label>
          <select id="calc-pct">
            <option value="5">5%</option>
            <option value="10" selected>10%</option>
            <option value="15">15%</option>
            <option value="20">20%</option>
            <option value="25">25%</option>
          </select>
        </div>
        <div class="field">
          <label for="calc-days">{c.labelInterval}</label>
          <select id="calc-days">
            <option value="7">7</option>
            <option value="14" selected>14</option>
            <option value="21">21</option>
            <option value="28">28</option>
          </select>
        </div>
        <div class="field">
          <label for="calc-target">{c.labelTarget}</label>
          <select id="calc-target">
            <option value="0.05" selected>5%</option>
            <option value="0.1">10%</option>
            <option value="0.025">2.5%</option>
          </select>
          <div class="hint">{c.hintTarget}</div>
        </div>
      </div>
      <p style="margin-top:1.4rem; margin-bottom:0">
        <button class="btn btn-primary" id="calc-run">{c.generate}</button>
      </p>

      <div class="calc-chart" id="calc-chart" hidden>
        <h3 style="margin-top:1.8rem">{c.chartTitle}</h3>
        <svg id="calc-svg" viewBox="0 0 640 300" role="img"></svg>
        <p id="calc-summary" class="muted"></p>
      </div>

      <div id="calc-out" hidden>
        <table class="calc-table">
          <thead>
            <tr>
              <th>{c.colStep}</th>
              <th>{c.colDay}</th>
              <th>{c.colDose}</th>
              <th>{c.colReduction}</th>
            </tr>
          </thead>
          <tbody id="calc-rows"></tbody>
        </table>
      </div>
    </div>

    <div class="callout">
      <p>⚠️ {c.disclaimer}</p>
    </div>

    <h2>{c.methodHeading}</h2>
    <p style="max-width:52rem">{c.methodBody}</p>

    <div class="faq-list">
      {c.faq.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <div><p>{item.a}</p></div>
        </details>
      ))}
    </div>

    <div class="callout" style="border-left-color: var(--mint); background: var(--mint-wash); margin-top:2.4rem">
      <p>
        {c.appBridge}
        <a href={APP_STORE_URL} rel="noopener" style="font-weight:700">App Store</a> ·
        <a href={localePath(locale, '/')} style="font-weight:700">RxDown →</a>
      </p>
    </div>
  </div>
</section>

<script
  is:inline
  define:vars={{
    summaryPrefix: c.summaryPrefix,
    summaryWeeks: c.summaryWeeks,
    summarySteps: c.summarySteps,
  }}
>
  (function () {
    var $ = function (id) { return document.getElementById(id); };

    function schedule(start, pct, days, targetFrac) {
      var rows = [{ step: 0, day: 0, dose: start, cut: 0 }];
      var dose = start;
      var target = start * targetFrac;
      var i = 0;
      while (dose > target && i < 60) {
        i++;
        var next = dose * (1 - pct);
        var cut = dose - next;
        if (next < target) next = target;
        rows.push({ step: i, day: i * days, dose: next, cut: cut });
        dose = next;
        if (next <= target) break;
      }
      return rows;
    }

    function fmt(n) {
      return n >= 100 ? n.toFixed(0) : n >= 10 ? n.toFixed(1) : n.toFixed(2);
    }

    function draw(rows, unit) {
      var svg = $('calc-svg');
      var W = 640, H = 300, PL = 46, PB = 34, PT = 14, PR = 14;
      var maxDose = rows[0].dose, maxDay = rows[rows.length - 1].day || 1;
      var x = function (d) { return PL + (d / maxDay) * (W - PL - PR); };
      var y = function (v) { return PT + (1 - v / maxDose) * (H - PT - PB); };
      var pts = rows.map(function (r) { return x(r.day) + ',' + y(r.dose); });
      var area = 'M' + PL + ',' + y(rows[0].dose) + ' L' + pts.join(' L') +
                 ' L' + x(maxDay) + ',' + (H - PB) + ' L' + PL + ',' + (H - PB) + ' Z';
      var html = '';
      html += '<path class="plot-area" d="' + area + '"/>';
      html += '<line class="axis" x1="' + PL + '" y1="' + PT + '" x2="' + PL + '" y2="' + (H - PB) + '"/>';
      html += '<line class="axis" x1="' + PL + '" y1="' + (H - PB) + '" x2="' + (W - PR) + '" y2="' + (H - PB) + '"/>';
      html += '<polyline class="plot-line" points="' + pts.join(' ') + '"/>';
      rows.forEach(function (r) {
        html += '<circle class="plot-dot" r="3.5" cx="' + x(r.day) + '" cy="' + y(r.dose) + '"/>';
      });
      [0, 0.5, 1].forEach(function (f) {
        var v = maxDose * f;
        html += '<text class="axis-label" x="' + (PL - 8) + '" y="' + (y(v) + 4) + '" text-anchor="end">' + fmt(v) + '</text>';
      });
      [0, 0.5, 1].forEach(function (f) {
        var d = Math.round(maxDay * f);
        html += '<text class="axis-label" x="' + x(d) + '" y="' + (H - PB + 18) + '" text-anchor="middle">' + d + 'd</text>';
      });
      svg.innerHTML = html;
      var weeks = Math.round(maxDay / 7);
      $('calc-summary').textContent =
        summaryPrefix + ' ' + weeks + ' ' + summaryWeeks + ' (' + (rows.length - 1) + ' ' + summarySteps + ').';
    }

    $('calc-run').addEventListener('click', function () {
      var start = parseFloat($('calc-dose').value);
      if (!isFinite(start) || start <= 0) return;
      var unit = $('calc-unit').value;
      var rows = schedule(
        start,
        parseFloat($('calc-pct').value) / 100,
        parseInt($('calc-days').value, 10),
        parseFloat($('calc-target').value)
      );
      var tbody = $('calc-rows');
      tbody.innerHTML = rows
        .map(function (r) {
          return (
            '<tr><td>' + r.step + '</td><td>' + r.day + '</td><td>' +
            fmt(r.dose) + ' ' + unit + '</td><td>' +
            (r.step === 0 ? '—' : '−' + fmt(r.cut) + ' ' + unit) + '</td></tr>'
          );
        })
        .join('');
      $('calc-out').hidden = false;
      $('calc-chart').hidden = false;
      draw(rows, unit);
    });
  })();
</script>
