---
import { STRINGS, localePath, APP_STORE_URL, PLAY_STORE_URL } from '../i18n/locales.js';
const { locale } = Astro.props;
const t = STRINGS[locale];
---

<section class="hero">
  <div class="hero-curve" aria-hidden="true">
    <svg viewBox="0 0 620 420" fill="none">
      <path
        class="curve-path"
        d="M30 60 C 150 78, 230 150, 310 240 C 380 316, 470 358, 590 372"
      />
      <circle class="curve-dot" cx="30" cy="60" r="5" style="animation-delay:.4s" />
      <circle class="curve-dot" cx="170" cy="90" r="5" style="animation-delay:.7s" />
      <circle class="curve-dot" cx="300" cy="228" r="5" style="animation-delay:1s" />
      <circle class="curve-dot" cx="430" cy="330" r="5" style="animation-delay:1.3s" />
      <circle class="curve-dot" cx="560" cy="368" r="5" style="animation-delay:1.6s" />
    </svg>
  </div>
  <div class="wrap hero-grid">
    <div class="hero-kicker">
      <span class="eyebrow rise">{t.hero.eyebrow}</span>
      <h1 class="rise" style="animation-delay:.08s">{t.hero.h1}</h1>
      <p class="lede rise" style="animation-delay:.16s">{t.hero.lede}</p>
      <div class="hero-actions rise" style="animation-delay:.24s">
        <a class="btn btn-primary" href={APP_STORE_URL} rel="noopener"> {t.hero.ctaAppStore}</a>
        <a class="btn btn-ghost" href={PLAY_STORE_URL} rel="noopener">▶ {t.hero.ctaPlay}</a>
      </div>
      <p class="small rise" style="animation-delay:.32s; margin-top:1.1rem">{t.hero.note}</p>
      <p class="small rise" style="animation-delay:.36s">{t.hero.formerly}</p>
    </div>
    <div class="hero-phones rise" style="animation-delay:.2s">
      <img
        src="/shots/today.webp"
        alt={t.how.steps[1].title}
        width="207"
        height="424"
        fetchpriority="high"
      />
      <img
        src="/shots/voice.webp"
        alt={t.how.steps[0].title}
        width="207"
        height="424"
        loading="lazy"
      />
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <p class="lede" style="max-width:52rem">{t.answerFirst}</p>
  </div>
</section>

<section class="section section-deep">
  <div class="wrap">
    <h2>{t.how.heading}</h2>
    <div class="steps">
      {t.how.steps.map((s) => (
        <div class="step">
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <h2>{t.features.heading}</h2>
    <div class="grid">
      {t.features.cards.map((c) => (
        <div class="card">
          <h3>
            <span class="ico">{c.icon}</span>
            {c.title}
            {c.isNew && <span class="badge-new">NEW</span>}
          </h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <h2>{t.gallery.heading}</h2>
  </div>
  <div class="gallery" tabindex="0">
    <img src="/shots/journey.webp" alt={t.how.steps[1].title} width="207" height="424" loading="lazy" />
    <img src="/shots/insights.webp" alt={t.features.cards[1].title} width="207" height="424" loading="lazy" />
    <img src="/shots/ai.webp" alt={t.features.cards[0].title} width="207" height="424" loading="lazy" />
    <img src="/shots/report.webp" alt={t.features.cards[5].title} width="207" height="424" loading="lazy" />
    <img src="/shots/log.webp" alt={t.how.steps[0].title} width="207" height="424" loading="lazy" />
    <img src="/shots/export.webp" alt={t.features.cards[5].title} width="207" height="424" loading="lazy" />
  </div>
</section>

<section class="section section-deep">
  <div class="wrap">
    <h2>{t.evidence.heading}</h2>
    <p>{t.evidence.body1}</p>
    <p>{t.evidence.body2}</p>
    <p>{t.evidence.body3}</p>
    <div class="evidence">
      {t.evidence.sources.map((s) => <span>{s}</span>)}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <h2>{t.privacyPromise.heading}</h2>
    <p style="max-width:48rem">{t.privacyPromise.body}</p>
    <a href={localePath(locale, '/privacy/')}>{t.privacyPromise.link} →</a>
  </div>
</section>

<section class="section section-deep">
  <div class="wrap">
    <h2>{t.faqTeaser.heading}</h2>
    <div class="faq-list">
      {t.faqPage.items.slice(0, 3).map((item) => (
        <details>
          <summary>{item.q}</summary>
          <div><p>{item.a}</p></div>
        </details>
      ))}
    </div>
    <p style="margin-top:1.4rem">
      <a class="btn btn-ghost" href={localePath(locale, '/faq/')}>{t.faqTeaser.cta}</a>
    </p>
  </div>
</section>

<section class="section">
  <div class="wrap" style="text-align:center">
    <h2>{t.finalCta.heading}</h2>
    <p style="margin-inline:auto">{t.finalCta.body}</p>
    <div class="hero-actions" style="justify-content:center">
      <a class="btn btn-primary" href={APP_STORE_URL} rel="noopener"> {t.hero.ctaAppStore}</a>
      <a class="btn btn-ghost" href={PLAY_STORE_URL} rel="noopener">▶ {t.hero.ctaPlay}</a>
    </div>
    <p class="small" style="margin-top:1.2rem">{t.finalCta.formerly}</p>
  </div>
</section>
