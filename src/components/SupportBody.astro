---
import { STRINGS, SUPPORT_EMAIL } from '../i18n/locales.js';
const { locale } = Astro.props;
const t = STRINGS[locale];
---

<section class="section">
  <div class="wrap">
    <span class="eyebrow">RxDown</span>
    <h1>{t.support.h1}</h1>
    <p class="lede" style="max-width:44rem">{t.support.answerFirst}</p>
    <p>
      <a class="btn btn-primary" href={`mailto:${SUPPORT_EMAIL}`}>✉️ {t.support.emailLabel}</a>
    </p>
    <p class="small">{SUPPORT_EMAIL} — {t.support.responseNote}</p>

    <h2 style="margin-top:2.6rem">{t.support.topicsHeading}</h2>
    <div class="grid">
      {t.support.topics.map((topic) => (
        <div class="card">
          <h3>{topic.title}</h3>
          <p>{topic.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
