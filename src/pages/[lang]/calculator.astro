---
import Base from '../../layouts/Base.astro';
import CalcBody from '../../components/CalcBody.astro';
import { NON_DEFAULT_LOCALES, STRINGS } from '../../i18n/locales.js';
import { faqLd, breadcrumbLd } from '../../i18n/jsonld.js';
export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const t = STRINGS[lang];
---
<Base locale={lang} page="calculator" path="/calculator/" jsonLd={[faqLd(t.calc.faq), breadcrumbLd(lang, '/calculator/', t.calc.h1)]}>
  <CalcBody locale={lang} />
</Base>
