---
import { render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { articleLd, faqLd, breadcrumbLd } from '../../../i18n/jsonld.js';
import { LOCALES, NON_DEFAULT_LOCALES } from '../../../i18n/locales.js';
import { GUIDES_UI } from '../../../i18n/guides-ui.js';
import {
  guidesForLocale,
  guidePath,
  guidesIndexPath,
  guideAlternates,
} from '../../../i18n/guides.js';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of NON_DEFAULT_LOCALES) {
    const guides = await guidesForLocale(lang);
    for (const { entry, slug } of guides) {
      paths.push({ params: { lang, slug }, props: { entry, slug } });
    }
  }
  return paths;
}

const { lang } = Astro.params;
const { entry, slug } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const gt = GUIDES_UI[lang];
const path = guidePath(lang, slug);
const url = `https://rxdown.app${path}`;
const heroImage = `/guides/${slug}.png`;

const alts = await guideAlternates(slug);
const alternates = alts.map((a) => ({ hreflang: LOCALES[a.locale].hreflang, href: a.path }));

const fmt = (x) =>
  x.toLocaleDateString(LOCALES[lang].hreflang, { year: 'numeric', month: 'long', day: 'numeric' });

const related = (await guidesForLocale(lang))
  .filter((g) => g.slug !== slug)
  .filter((g) => g.entry.data.tags.some((t) => d.tags.includes(t)))
  .slice(0, 3);
---

<Base
  locale={lang}
  page="guides"
  path={path}
  customAlternates={alternates}
  titleOverride={`${d.title} | RxDown`}
  descriptionOverride={d.description}
  ogImagePath={heroImage}
  jsonLd={[articleLd(entry, url, slug, lang), faqLd(d.faq), breadcrumbLd(lang, path, d.title, gt.crumb, guidesIndexPath(lang))]}
>
  <article class="guide prose wrap">
    <nav class="guide-crumbs small">
      <a href={guidesIndexPath(lang)}>{gt.crumb}</a> <span aria-hidden="true">›</span> {d.title}
    </nav>
    <h1>{d.title}</h1>
    <p class="guide-byline small">
      {gt.by} <strong>Chih Yu Lin</strong>, {gt.role} · {gt.published} {fmt(d.pubDate)}
      {d.updatedDate && <> · {gt.updated} {fmt(d.updatedDate)}</>}
    </p>
    <div class="callout guide-disclaimer">
      <p>⚕️ {gt.disclaimer}</p>
    </div>

    <img
      class="guide-hero"
      src={heroImage}
      width="1200"
      height="630"
      decoding="async"
      alt={`${gt.diagramAlt}: ${d.title}`}
    />

    <Content />

    <section class="guide-faq">
      <h2>{gt.faqHeading}</h2>
      <div class="faq-list">
        {d.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <div><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </section>

    {related.length > 0 && (
      <section class="guide-related">
        <h2>{gt.keepReading}</h2>
        <ul>
          {related.map((g) => (
            <li><a href={guidePath(lang, g.slug)}>{g.entry.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <div class="callout" style="border-left-color: var(--mint); background: var(--mint-wash)">
      <p>
        {gt.ctaText}{' '}
        <a href={`/${lang}/`} style="font-weight:700">{gt.ctaApp}</a>
        {' · '}
        <a href={`/${lang}/calculator/`} style="font-weight:700">{gt.ctaCalc}</a>
      </p>
    </div>
  </article>
</Base>
