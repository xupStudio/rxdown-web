---
import Base from '../../layouts/Base.astro';
import HomeBody from '../../components/HomeBody.astro';
import { NON_DEFAULT_LOCALES, STRINGS } from '../../i18n/locales.js';
import { softwareAppLd } from '../../i18n/jsonld.js';
export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
---
<Base locale={lang} page="home" path="/" jsonLd={[softwareAppLd(STRINGS[lang])]}>
  <HomeBody locale={lang} />
</Base>
