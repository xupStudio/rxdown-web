---
import Base from '../../layouts/Base.astro';
import SupportBody from '../../components/SupportBody.astro';
import { NON_DEFAULT_LOCALES, STRINGS } from '../../i18n/locales.js';
import { breadcrumbLd } from '../../i18n/jsonld.js';
export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const t = STRINGS[lang];
---
<Base locale={lang} page="support" path="/support/" jsonLd={[breadcrumbLd(lang, '/support/', t.support.h1)]}>
  <SupportBody locale={lang} />
</Base>
