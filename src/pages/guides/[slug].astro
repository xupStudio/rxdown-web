---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { articleLd, faqLd, breadcrumbLd } from '../../i18n/jsonld.js';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const path = `/guides/${entry.id}/`;
const url = `https://rxdown.app${path}`;
const fmt = (x) =>
  x.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const related = (await getCollection('guides'))
  .filter((g) => g.id !== entry.id)
  .filter((g) => g.data.tags.some((t) => d.tags.includes(t)))
  .slice(0, 3);
---

<Base
  locale="en"
  page="home"
  path={path}
  noAlternates={true}
  titleOverride={`${d.title} | RxDown Guides`}
  descriptionOverride={d.description}
  jsonLd={[articleLd(entry, url), faqLd(d.faq), breadcrumbLd('en', path, d.title)]}
>
  <article class="guide prose wrap">
    <nav class="guide-crumbs small">
      <a href="/guides/">Guides</a> <span aria-hidden="true">›</span> {d.title}
    </nav>
    <h1>{d.title}</h1>
    <p class="guide-byline small">
      By <strong>Chih Yu Lin</strong>, RxDown founder · Published {fmt(d.pubDate)}
      {d.updatedDate && <> · Updated {fmt(d.updatedDate)}</>}
    </p>
    <div class="callout guide-disclaimer">
      <p>
        ⚕️ This article is education, not medical advice. Every claim is
        sourced below. Never stop or change medication without your
        prescriber — some medications are dangerous to stop abruptly.
      </p>
    </div>

    <Content />

    <section class="guide-faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {d.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <div><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </section>

    {related.length > 0 && (
      <section class="guide-related">
        <h2>Keep reading</h2>
        <ul>
          {related.map((g) => (
            <li><a href={`/guides/${g.id}/`}>{g.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <div class="callout" style="border-left-color: var(--mint); background: var(--mint-wash)">
      <p>
        Tracking your own dose, sleep, and symptoms makes every conversation
        in this article easier. <a href="/" style="font-weight:700">RxDown</a>
        is a free diary built for exactly that — or start with the free
        <a href="/calculator/" style="font-weight:700"> taper calculator</a>.
      </p>
    </div>
  </article>
</Base>
